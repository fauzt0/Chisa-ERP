// define('API_TOKEN', '...');

function escribir_log($archivo, $contenido, $append = true) {
    $flags = $append ? FILE_APPEND | LOCK_EX : LOCK_EX;
    $ok = @file_put_contents($archivo, $contenido, $flags);
    if ($ok === false) {
        error_log("iclock: no se pudo escribir en $archivo");
    }
    return $ok !== false;
}
